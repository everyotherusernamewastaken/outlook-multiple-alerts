{
  "name": "outlook-multiple-alerts",
  "version": "1.0.0",
  "description": "Outlook Desktop Add-in for managing multiple alerts per calendar event or task",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "start": "office-addin-debugging start manifest.xml desktop",
    "stop": "office-addin-debugging stop manifest.xml",
    "deploy:setup": "node update-manifest-urls.js"
  },
  "keywords": ["outlook", "add-in", "alerts", "reminders"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/office-js": "^1.0.0",
    "@types/uuid": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "fast-check": "^3.15.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "dependencies": {
    "@microsoft/office-js": "^1.1.0",
    "uuid": "^9.0.0"
  }
}
